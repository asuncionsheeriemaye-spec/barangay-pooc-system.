<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barangay.controllers.DashboardController"
      style="-fx-background-color: #f0f4f8;">

    <padding>
        <Insets top="16" right="20" bottom="16" left="20"/>
    </padding>

    <!-- ── Header Bar ─────────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🏛 Barangay Niugan Resident Information System"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;">
            <font><Font name="System Bold" size="16"/></font>
        </Label>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="⟳ Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color: #4a90d9; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
        <Button text="Logout"
                onAction="#handleLogout"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <Separator/>

    <!-- ── Add Resident Form ──────────────────────────────────────────────── -->
    <Label text="Add New Resident"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">

        <!-- Name -->
        <VBox spacing="4">
            <Label text="Full Name *" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            <TextField fx:id="nameField"
                       promptText="e.g. Juan dela Cruz"
                       prefWidth="220"
                       style="-fx-border-color: #aec6e8; -fx-border-radius: 4;
                              -fx-background-radius: 4; -fx-padding: 5;"/>
        </VBox>

        <!-- Age -->
        <VBox spacing="4">
            <Label text="Age *" style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            <TextField fx:id="ageField"
                       promptText="e.g. 35"
                       prefWidth="80"
                       style="-fx-border-color: #aec6e8; -fx-border-radius: 4;
                              -fx-background-radius: 4; -fx-padding: 5;"/>
        </VBox>

        <!-- Contact -->
        <VBox spacing="4">
            <Label text="Contact No." style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
            <TextField fx:id="contactField"
                       promptText="e.g. 09171234567"
                       prefWidth="150"
                       style="-fx-border-color: #aec6e8; -fx-border-radius: 4;
                              -fx-background-radius: 4; -fx-padding: 5;"/>
        </VBox>

        <!-- Add Button (bottom-aligned) -->
        <VBox spacing="4" alignment="BOTTOM_LEFT">
            <Label text=" " style="-fx-font-size: 11px;"/>
            <Button text="+ Add Resident"
                    onAction="#handleAdd"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 4;
                           -fx-padding: 6 14; -fx-cursor: hand;"/>
        </VBox>

    </HBox>

    <!-- Status / feedback label -->
    <Label fx:id="statusLabel"
           text=""
           style="-fx-font-size: 11px; -fx-text-fill: #007700;"/>

    <Separator/>

    <!-- ── Residents TableView ────────────────────────────────────────────── -->
    <Label text="Registered Residents"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a3c5e;"/>

    <TableView fx:id="residentTable"
               VBox.vgrow="ALWAYS"
               style="-fx-border-color: #c8d8ea; -fx-border-radius: 4;">
        <columns>
            <TableColumn fx:id="colId"      text="ID"         prefWidth="50"/>
            <TableColumn fx:id="colName"    text="Full Name"  prefWidth="220"/>
            <TableColumn fx:id="colAge"     text="Age"        prefWidth="70"/>
            <TableColumn fx:id="colContact" text="Contact No." prefWidth="150"/>
        </columns>
        <placeholder>
            <Label text="No residents found. Add one above!" style="-fx-text-fill: #888;"/>
        </placeholder>
    </TableView>

    <!-- ── Delete Row ─────────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_RIGHT">
        <Button text="✕ Delete Selected"
                onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4;
                       -fx-padding: 6 14; -fx-cursor: hand;"/>
    </HBox>

</VBox>
