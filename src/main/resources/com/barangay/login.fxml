<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER"
      spacing="12"
      prefHeight="480.0"
      prefWidth="400.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barangay.controllers.LoginController"
      style="-fx-background-color: #f0f4f8;">

    <padding>
        <Insets top="40" right="50" bottom="40" left="50"/>
    </padding>

    <!-- Title -->
    <Label text="🏛 Barangay Pooc Information System"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #800000;">
        <font>
            <Font name="System Bold" size="16"/>
        </font>
    </Label>

    <Label text="Admin Login"
           style="-fx-font-size: 12px; -fx-text-fill: #5a7a9a;"/>

    <!-- Spacer -->
    <Label text="" prefHeight="8"/>

    <!-- Username -->
    <Label text="Username:"
           style="-fx-font-size: 12px; -fx-text-fill: #333333;"
           maxWidth="300" prefWidth="300"/>
    <TextField fx:id="usernameField"
               promptText="Enter username"
               prefWidth="300"
               style="-fx-border-color: #aec6e8; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>

    <!-- Password -->
    <Label text="Password:"
           style="-fx-font-size: 12px; -fx-text-fill: #333333;"
           maxWidth="300" prefWidth="300"/>
    <PasswordField fx:id="passwordField"
                   promptText="Enter password"
                   prefWidth="300"
                   style="-fx-border-color: #aec6e8; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>

    <!-- Error / Status Label -->
    <Label fx:id="errorLabel"
           text=""
           prefWidth="300"
           maxWidth="300"
           wrapText="true"
           style="-fx-text-fill: #cc0000; -fx-font-size: 11px;"/>

    <!-- Login Button -->
    <Button text="Login"
            prefWidth="300"
            onAction="#handleLogin"
            style="-fx-background-color: #800000; -fx-text-fill: white;
                   -fx-font-size: 13px; -fx-font-weight: bold;
                   -fx-background-radius: 5; -fx-padding: 8;
                   -fx-cursor: hand;"/>
</VBox>
